# Copy to .env and fill in (`cp env.example .env`). .env is gitignored.

# Band platform URLs (production defaults)
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# LLM provider key that powers the agents' reasoning
ANTHROPIC_API_KEY=sk-ant-...

# Engagement target (deliberately-vulnerable lab only — authorized scope)
LEASH_TARGET_HOST=localhost
LEASH_TARGET_PORT=3000
